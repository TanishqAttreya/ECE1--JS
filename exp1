<!DOCTYPE html>
<html>
<head>
<title>Result Calculator</title>
<style>
body{
    font-family: Arial;
    text-align: center;
    margin-top: 40px;}
input,button{
    padding:8px;
    margin:5px;}
#result{
    margin-top:20px;
    font-size:18px;}
</style> <script>
function calculateResult(){
let subjects = parseInt(document.getElementById("subjects").value);
let total = 0;
for(let i = 1; i <= subjects; i++){
let marks = parseFloat(prompt("Enter marks for subject " + i));
total= total + marks;}
let average= total/subjects;
let grade; let result;
if(average >= 90){
grade="A";}
else if(average >= 75){
grade="B";}
else if(average >= 50){
grade="C";}
else{
grade="F";}
if(average >= 40){
result="Pass";}
else{
result="Fail";}
document.getElementById("result").innerHTML =
"Total Marks: " + total + "<br>" +
"Average Marks: " + average + "<br>" +
"Grade: " + grade + "<br>" +
"Result: " + result;}
</script> </head>
<body>
<h2>Student Result Calculator</h2>
<label>Enter Number of Subjects</label><br>
<input type="number" id="subjects"><br>
<button onclick="calculateResult()">Calculate Result</button>
<div id="result"></div>
</body></html>